# Groq API Configuration
# Get your free API key at: https://console.groq.com/
GROQ_API_KEY=your-groq-api-key-here

# Whisper Configuration
WHISPER_CPP_PATH=/path/to/whisper.cpp/build/bin/whisper-cli
WHISPER_MODEL=/path/to/whisper.cpp/models/ggml-base.en.bin

# Silero VAD model (optional) - enables --vad to strip silence before decoding,
# the primary defense against hallucinated boilerplate on quiet audio.
# Download: cd whisper.cpp && bash models/download-vad-model.sh silero-v5.1.2
# WHISPER_VAD_MODEL=/path/to/whisper.cpp/models/ggml-silero-v5.1.2.bin

# Output Configuration
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# Speaker Diarization (optional)
# Required only for --diarize flag. Get token at: https://huggingface.co/settings/tokens
HUGGINGFACE_TOKEN=hf_your_token_here

# Required for --transcription_provider elevenlabs
# Get your API key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# Tools
FFMPEG_PATH=ffmpeg
